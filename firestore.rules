rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Liens publics https://kelegance.web.app/doc/{token}
    match /documents_client/{token} {
      allow read: if true;
      allow write: if false;
    }

    // Présence équipe — lecture par tout authentifié ; écriture soi ou admin (dispatch).
    match /presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid
        || (
          resource != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sollicitationDispatch', 'updatedAt'])
        )
      );
    }

    match /profils_chauffeur/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Profils — lecture par tout utilisateur authentifié (liste équipe / dispatch).
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /chauffeurs/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Missions, factures, etc. — authentifié (règles fines à affiner plus tard).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
