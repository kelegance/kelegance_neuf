# Kelegance — pas de cache agressif sur le shell Flutter (évite les versions figées).
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/app.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/flutter_bootstrap.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/main.dart.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/version.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/kelegance-version-check.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/flutter_service_worker.js
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex

/hub/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /hub/

/releases/web-latest.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
